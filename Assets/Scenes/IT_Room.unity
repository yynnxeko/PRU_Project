      ty ch\xEDnh th\u1EE9c v\xE0 kh\xF4ng \u0111\xF3ng ph\xED \u1EE9ng tuy\u1EC3n."
    choice1: "Anh/ch\u1ECB c\xE2n nh\u1EAFc l\u1EA1i nh\xE9, v\xEC khi h\u1ED3 s\u01A1
      b\u1ECB \u0111\xF3ng r\u1ED3i th\xEC r\u1EA5t kh\xF3 m\u1EDF l\u1EA1i trong
      \u0111\u1EE3t tuy\u1EC3n n\xE0y."
    choice2: "N\u1EBFu anh/ch\u1ECB mu\u1ED1n an to\xE0n qu\xE1 m\u1EE9c th\xEC em
      c\u0169ng ch\u1ECBu, nh\u01B0ng c\u01A1 h\u1ED9i t\u1ED1t th\u01B0\u1EDDng
      kh\xF4ng ch\u1EDD l\xE2u \u0111\xE2u."
    choice3: "Th\xF4i \u0111\u01B0\u1EE3c \u1EA1, em d\u1EEBng h\u1ED7 tr\u1EE3 t\u1EA1i
      \u0111\xE2y, nh\u01B0ng \u0111\xFAng l\xE0 m\xECnh \u0111ang b\u1ECF l\u1EE1
      m\u1ED9t v\u1ECB tr\xED kh\xE1 \u1ED5n \u0111\xF3."
    choice4: "Anh/ch\u1ECB c\u1EE9 ki\u1EC3m tra th\xEAm c\u0169ng \u0111\u01B0\u1EE3c,
      c\xF2n b\xEAn em s\u1EBD chuy\u1EC3n su\u1EA5t n\xE0y cho ng\u01B0\u1EDDi x\xE1c
      nh\u1EADn s\u1EDBm h\u01A1n."
    correctIndex: 0
  - question: "1. Alo, ai \u0111ang g\u1ECDi cho t\xF4i v\u1EADy?"
    choice1: "Ch\xE0o ph\u1EE5 huynh, em g\u1ECDi t\u1EEB ph\xF2ng t\xE0i v\u1EE5
      nh\xE0 tr\u01B0\u1EDDng v\xEC h\u1ECDc ph\xED c\u1EE7a em nh\xE0 m\xECnh \u0111ang
      c\xF3 v\u1EA5n \u0111\u1EC1."
    choice2: 
    choice3: 
    choice4: 
    correctIndex: 0
  - question: "2. V\u1EA5n \u0111\u1EC1 g\xEC? T\xF4i t\u01B0\u1EDFng \u0111\xE3
      \u0111\xF3ng \u0111\u1EE7 t\u1EEB \u0111\u1EA7u k\u1EF3 r\u1ED3i m\xE0."
    choice1: "H\u1EC7 th\u1ED1ng k\u1EBF to\xE1n b\xE1o kho\u1EA3n h\u1ECDc ph\xED
      k\u1EF3 n\xE0y ch\u01B0a \u0111\u01B0\u1EE3c x\xE1c nh\u1EADn ho\xE0n t\u1EA5t
      n\xEAn c\u1EA7n ki\u1EC3m tra g\u1EA5p."
    choice2: "C\xF3 th\u1EC3 ph\u1EA7n m\u1EC1m nh\u1EDB nh\u1EA7m m\u1ED9t ch\xFAt
      th\xF4i, nh\u01B0ng m\xECnh c\u1EE9 x\u1EED l\xFD tr\u01B0\u1EDBc cho y\xEAn
      t\xE2m c\u0169ng \u0111\u01B0\u1EE3c \u1EA1."
    choice3: "\u0110\xF4i khi d\u1EEF li\u1EC7u \u0111i h\u01A1i ch\u1EADm n\xEAn
      tr\u01B0\u1EDDng g\u1ECDi h\u1ECFi l\u1EA1i tr\u01B0\u1EDBc \u0111\u1EC3 tr\xE1nh
      ph\u1EE5 huynh ph\u1EA3i \u0111i l\u1EA1i nhi\u1EC1u."
    choice4: "Em c\u0169ng ch\u01B0a r\xF5 chi ti\u1EBFt l\u1EAFm, ch\u1EC9 th\u1EA5y
      m\xE0n h\xECnh b\xE1o \u0111\u1ECF n\xEAn g\u1ECDi m\xECnh tr\u01B0\u1EDBc
      cho ch\u1EAFc th\xF4i \u1EA1."
    correctIndex: 0
  - question: "3. T\xF4i kh\xF4ng h\u1EC1 nh\u1EADn \u0111\u01B0\u1EE3c th\xF4ng
      b\xE1o n\xE0o t\u1EEB gi\xE1o vi\xEAn ch\u1EE7 nhi\u1EC7m."
    choice1: "Do \u0111\xE2y l\xE0 l\u1ED7i ph\xE1t sinh \u1EDF h\u1EC7 th\u1ED1ng
      thu ph\xED n\xEAn b\xEAn em g\u1ECDi tr\u1EF1c ti\u1EBFp \u0111\u1EC3 x\u1EED
      l\xFD tr\u01B0\u1EDBc cho nhanh."
    choice2: "C\xF3 th\u1EC3 gi\xE1o vi\xEAn b\u1EADn n\xEAn ch\u01B0a k\u1ECBp b\xE1o,
      nh\u01B0ng m\xECnh l\xE0m s\u1EDBm th\xEC th\u01B0\u1EDDng s\u1EBD \u0111\u1EE1
      r\u1EAFc r\u1ED1i h\u01A1n \u1EA1."
    choice3: "Th\xF4ng b\xE1o gi\u1EA5y nhi\u1EC1u khi \u0111\u1EBFn ch\u1EADm l\u1EAFm,
      n\xEAn tr\u01B0\u1EDDng m\u1EDBi \u01B0u ti\xEAn g\u1ECDi \u0111i\u1EC7n \u0111\u1EC3
      ph\u1EE5 huynh n\u1EAFm tr\u01B0\u1EDBc."
    choice4: "N\u1EBFu \u0111\u1EE3i \u0111\u1EE7 c\xE1c \u0111\u1EA7u m\u1ED1i c\xF9ng
      b\xE1o th\xEC h\u01A1i l\xE2u, trong khi h\u1ED3 s\u01A1 h\u1ECDc v\u1EE5 v\u1EABn
      \u0111ang ch\u1EA1y li\xEAn t\u1EE5c \u1EA1."
    correctIndex: 0
  - question: "4. V\u1EADy gi\u1EDD t\xF4i c\u1EA7n l\xE0m g\xEC?"
    choice1: "Ph\u1EE5 huynh c\u1EA7n x\xE1c nh\u1EADn l\u1EA1i m\xE3 h\u1ECDc sinh
      v\xE0 ho\xE0n t\u1EA5t kho\u1EA3n b\u1ED5 sung \u0111\u1EC3 tr\xE1nh kh\xF3a
      h\u1ED3 s\u01A1 h\u1ECDc v\u1EE5."
    choice2: "M\xECnh ch\u1EC9 c\u1EA7n l\xE0m th\xEAm m\u1ED9t b\u01B0\u1EDBc nh\u1ECF
      th\xF4i, sau \u0111\xF3 h\u1EC7 th\u1ED1ng s\u1EBD t\u1EF1 c\u1EADp nh\u1EADt
      l\u1EA1i tr\u1EA1ng th\xE1i ngay \u1EA1."
    choice3: "Quy tr\xECnh c\u0169ng kh\xE1 ng\u1EAFn, b\xEAn em h\u01B0\u1EDBng
      d\u1EABn qua \u0111i\u1EC7n tho\u1EA1i n\xEAn ph\u1EE5 huynh kh\xF4ng ph\u1EA3i
      \u0111\u1EBFn tr\u01B0\u1EDDng \u0111\xE2u."
    choice4: "N\u1EBFu x\u1EED l\xFD ngay trong h\xF4m nay th\xEC h\u1ED3 s\u01A1
      s\u1EBD \u1ED5n \u0111\u1ECBnh, c\xF2n \u0111\u1EC3 sang ng\xE0y mai d\u1EC5
      ph\xE1t sinh ch\u1EADm h\u01A1n \u1EA1."
    correctIndex: 0
  - question: "5. Kho\u1EA3n b\u1ED5 sung l\xE0 kho\u1EA3n g\xEC? Nh\xE0 tr\u01B0\u1EDDng
      ch\u01B0a t\u1EEBng n\xF3i v\u1EDBi t\xF4i."
    choice1: "\u0110\xF3 l\xE0 ph\u1EA7n ch\xEAnh l\u1EC7ch c\u1EADp nh\u1EADt theo
      danh s\xE1ch m\u1EDBi, bao g\u1ED3m ph\xED h\u1ED3 s\u01A1 \u0111i\u1EC7n t\u1EED
      v\xE0 x\xE1c nh\u1EADn h\u1ECDc v\u1EE5."
    choice2: "Kho\u1EA3n n\xE0y kh\xF4ng l\u1EDBn \u0111\xE2u \u1EA1, ch\u1EE7 y\u1EBFu
      \u0111\u1EC3 h\u1EC7 th\u1ED1ng \u0111\u1EE7 \u0111i\u1EC1u ki\u1EC7n kh\xF3a
      d\u1EEF li\u1EC7u cho \u0111\xFAng t\u1EEBng h\u1ECDc sinh."
    choice3: "Nhi\u1EC1u ph\u1EE5 huynh c\u0169ng h\u1ECFi gi\u1ED1ng m\xECnh, v\xEC
      \u0111\u1EE3t \u0111i\u1EC1u ch\u1EC9nh n\xE0y ph\xE1t sinh sau khi \u0111\xE3
      thu h\u1ECDc ph\xED \u0111\u1EA7u k\u1EF3."
    choice4: "B\xEAn em \u0111ang h\u1ED7 tr\u1EE3 chung n\xEAn g\u1ECDi l\u1EA7n
      l\u01B0\u1EE3t t\u1EEBng ng\u01B0\u1EDDi, ph\u1EE5 huynh x\u1EED l\xFD s\u1EDBm
      s\u1EBD \u0111\u1EE1 ph\u1EA3i theo d\xF5i l\u1EA1i."
    correctIndex: 0
  - question: "6. T\xF4i mu\u1ED1n t\u1EF1 g\u1ECDi cho gi\xE1o vi\xEAn ch\u1EE7
      nhi\u1EC7m \u0111\u1EC3 h\u1ECFi tr\u01B0\u1EDBc."
    choice1: "Ph\u1EE5 huynh c\u1EE9 h\u1ECFi sau c\u0169ng \u0111\u01B0\u1EE3c,
      nh\u01B0ng h\u1ED3 s\u01A1 hi\u1EC7n \u0111ang treo n\xEAn c\u1EA7n x\u1EED
      l\xFD tr\u01B0\u1EDBc th\u1EDDi h\u1EA1n h\xF4m nay."
    choice2: "Gi\xE1o vi\xEAn ch\u1EE7 nhi\u1EC7m kh\xF4ng tr\u1EF1c ti\u1EBFp thao
      t\xE1c ph\u1EA7n t\xE0i v\u1EE5, n\xEAn g\u1ECDi l\xFAc n\xE0y c\u0169ng ch\u01B0a
      gi\u1EA3i quy\u1EBFt \u0111\u01B0\u1EE3c \u1EA1."
    choice3: "N\u1EBFu li\xEAn h\u1EC7 nhi\u1EC1u \u0111\u1EA7u m\u1ED1i c\xF9ng
      l\xFAc th\xEC th\xF4ng tin d\u1EC5 ch\u1ED3ng ch\xE9o, b\xEAn em s\u1EE3 ph\u1EE5
      huynh c\xE0ng r\u1ED1i h\u01A1n."
    choice4: "M\xECnh x\xE1c nh\u1EADn xong b\u01B0\u1EDBc n\xE0y tr\u01B0\u1EDBc
      r\u1ED3i h\u1ECFi l\u1EA1i sau v\u1EABn \u0111\u01B0\u1EE3c, v\xEC d\u1EEF
      li\u1EC7u hi\u1EC7n \u0111ang c\u1EA7n c\u1EADp nh\u1EADt g\u1EA5p."
    correctIndex: 0
  - question: "7. S\u1ED1 ti\u1EC1n c\u1EA7n \u0111\xF3ng l\xE0 bao nhi\xEAu?"
    choice1: "Ph\u1EE5 huynh chuy\u1EC3n 1 tri\u1EC7u 280 ngh\xECn v\xE0o t\xE0i
      kho\u1EA3n h\u1ED7 tr\u1EE3 thu ph\xED \u0111\u1EC3 b\xEAn em c\u1EADp nh\u1EADt
      ngay h\xF4m nay."
    choice2: "Kho\u1EA3n n\xE0y kh\xF4ng qu\xE1 l\u1EDBn \u0111\xE2u \u1EA1, ch\u1EE7
      y\u1EBFu l\xE0 ho\xE0n t\u1EA5t \u0111\xFAng h\u1EA1n \u0111\u1EC3 h\u1ED3
      s\u01A1 h\u1ECDc sinh kh\xF4ng b\u1ECB treo th\xEAm."
    choice3: "M\xECnh x\u1EED l\xFD s\u1EDBm th\xEC h\u1EC7 th\u1ED1ng s\u1EBD ghi
      nh\u1EADn ngay, ch\u1EE9 \u0111\u1EC3 tr\u1EC5 l\xE0 sang \u0111\u1EE3t \u0111\u1ED1i
      so\xE1t ti\u1EBFp theo kh\xE1 phi\u1EC1n \u1EA1."
    choice4: "B\xEAn em ch\u1EC9 c\u1EA7n th\u1EA5y giao d\u1ECBch v\xE0o h\u1EC7
      th\u1ED1ng l\xE0 c\xF3 th\u1EC3 m\u1EDF l\u1EA1i tr\u1EA1ng th\xE1i b\xECnh
      th\u01B0\u1EDDng cho h\u1ECDc sinh ngay."
    correctIndex: 0
  - question: "8. Sao l\u1EA1i chuy\u1EC3n v\xE0o t\xE0i kho\u1EA3n c\xE1 nh\xE2n?
      Tr\u01B0\u1EDDng kh\xF4ng c\xF3 c\u1ED5ng thanh to\xE1n \xE0?"
    choice1: "\u0110\xE2y l\xE0 t\xE0i kho\u1EA3n h\u1ED7 tr\u1EE3 \u0111\u1ED1i
      so\xE1t t\u1EA1m th\u1EDDi v\xEC c\u1ED5ng thu ph\xED \u0111ang b\u1EA3o tr\xEC
      n\xEAn b\xEAn em x\u1EED l\xFD th\u1EE7 c\xF4ng."
    choice2: "Ph\u1EE5 huynh y\xEAn t\xE2m, nhi\u1EC1u tr\u01B0\u1EDDng h\u1EE3p
      h\xF4m nay c\u0169ng \u0111ang l\xE0m theo c\xE1ch n\xE0y \u0111\u1EC3 k\u1ECBp
      th\u1EDDi h\u1EA1n c\u1EADp nh\u1EADt \u1EA1."
    choice3: "C\u1ED5ng thanh to\xE1n kh\xF4ng ph\u1EA3i l\xFAc n\xE0o c\u0169ng
      m\u1EDF \u1ED5n \u0111\u1ECBnh, n\xEAn b\xEAn em m\u1EDBi linh ho\u1EA1t h\u1ED7
      tr\u1EE3 qua t\xE0i kho\u1EA3n n\xE0y."
    choice4: "N\u1EBFu \u0111\u1EE3i c\u1ED5ng ch\xEDnh th\u1EE9c ho\u1EA1t \u0111\u1ED9ng
      l\u1EA1i th\xEC c\xF3 th\u1EC3 qu\xE1 h\u1EA1n, n\xEAn tr\u01B0\u1EDDng m\u1EDBi
      \u01B0u ti\xEAn x\u1EED l\xFD tr\u01B0\u1EDBc cho m\xECnh."
    correctIndex: 0
  - question: "9. T\xF4i v\u1EABn th\u1EA5y r\u1EA5t l\u1EA1 v\xE0 mu\u1ED1n xem
      th\xF4ng b\xE1o ch\xEDnh th\u1EE9c."
    choice1: "Em hi\u1EC3u, nh\u01B0ng danh s\xE1ch n\xE0y ch\u1EC9 gi\u1EEF \u0111\u1EBFn
      h\u1EBFt h\xF4m nay, qu\xE1 h\u1EA1n l\xE0 h\u1EC7 th\u1ED1ng t\u1EF1 chuy\u1EC3n
      sang nh\u1EAFc n\u1EE3."
    choice2: "Nhi\u1EC1u ph\u1EE5 huynh ban \u0111\u1EA7u c\u0169ng ph\xE2n v\xE2n
      v\u1EADy \u1EA1, nh\u01B0ng x\u1EED l\xFD xong th\xEC h\u1ED3 s\u01A1 \u0111\u1EC1u
      tr\u1EDF l\u1EA1i b\xECnh th\u01B0\u1EDDng ngay."
    choice3: "N\u1EBFu m\xECnh ch\u1EDD th\xEAm gi\u1EA5y t\u1EDD \u0111\u1EA7y \u0111\u1EE7
      th\xEC c\xF3 th\u1EC3 m\u1EA5t l\u01B0\u1EE3t x\u1EED l\xFD \u01B0u ti\xEAn
      v\xE0 ph\u1EA3i l\xE0m vi\u1EC7c l\u1EA1i t\u1EEB \u0111\u1EA7u \u1EA1."
    choice4: "B\xEAn em kh\xF4ng \xE9p \u0111\xE2u, ch\u1EC9 l\xE0 th\u1EDDi h\u1EA1n
      c\u1EE7a h\u1EC7 th\u1ED1ng kh\xE1 ch\u1EB7t n\xEAn ph\u1EA3n h\u1ED3i ch\u1EADm
      s\u1EBD b\u1EA5t ti\u1EC7n h\u01A1n th\xF4i."
    correctIndex: 0
  - question: "10. Kh\xF4ng, t\xF4i s\u1EBD li\xEAn h\u1EC7 gi\xE1o vi\xEAn ch\u1EE7
      nhi\u1EC7m v\xE0 ki\u1EC3m tra tr\xEAn k\xEAnh ch\xEDnh th\u1EE9c c\u1EE7a
      nh\xE0 tr\u01B0\u1EDDng."
    choice1: "Ph\u1EE5 huynh c\xE2n nh\u1EAFc l\u1EA1i nh\xE9, v\xEC khi h\u1ED3
      s\u01A1 b\u1ECB chuy\u1EC3n tr\u1EA1ng th\xE1i r\u1ED3i th\xEC vi\u1EC7c m\u1EDF
      l\u1EA1i s\u1EBD m\u1EA5t th\xEAm th\u1EDDi gian."
    choice2: "N\u1EBFu ph\u1EE5 huynh mu\u1ED1n ki\u1EC3m tra th\xEAm th\xEC em c\u0169ng
      kh\xF4ng c\u1EA3n, nh\u01B0ng h\u1EA1n x\u1EED l\xFD h\xF4m nay s\u1EBD kh\xF4ng
      ch\u1EDD l\xE2u \u0111\xE2u \u1EA1."
    choice3: "Th\xF4i \u0111\u01B0\u1EE3c \u1EA1, em d\u1EEBng h\u1ED7 tr\u1EE3 t\u1EA1i
      \u0111\xE2y, c\xF2n danh s\xE1ch n\xE0y b\xEAn em s\u1EBD chuy\u1EC3n sang
      ph\u1EE5 huynh kh\xE1c sau nh\xE9."
    choice4: "Ph\u1EE5 huynh c\u1EE9 x\xE1c minh th\xEAm c\u0169ng \u0111\u01B0\u1EE3c,
      nh\u01B0ng th\u1EADt s\u1EF1 l\xFAc n\xE0y m\xECnh \u0111ang \u1EDF r\u1EA5t
      g\u1EA7n b\u01B0\u1EDBc ho\xE0n t\u1EA5t r\u1ED3i \u1EA1."
    correctIndex: 0
